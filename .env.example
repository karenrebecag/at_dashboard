# =============================================================================
# ATFX Dashboard (atfx-dashboard) — copy to .env (never commit .env)
# =============================================================================

# --- Clerk (required — app won't start without this) ---
# https://dashboard.clerk.com → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=

# --- ATFX BFF (default) ---
# Browser calls same-origin /api/atfx. Token stays server-side (Vite proxy + Vercel).
# VITE_ATFX_USE_BFF=true
# VITE_ATFX_API_BASE=/api/atfx

# Server-only upstream (Vite dev proxy + Vercel Functions). Never prefix with VITE_.
ATFX_UPSTREAM_URL=https://atfxmcp.westus2.cloudapp.azure.com
ATFX_UPSTREAM_TOKEN=
ATFX_CACHE_TTL_MS=300000

# --- Legacy direct mode (optional) ---
# Set VITE_ATFX_USE_BFF=false to call the VM from the browser with Bearer token.
# VITE_ATFX_API_URL=https://atfxmcp.westus2.cloudapp.azure.com
# VITE_ATFX_API_TOKEN=

# --- ATFX client tuning (optional) ---
# TanStack Query staleTime for semantic endpoints (ms). Default: 60000
# VITE_ATFX_QUERY_STALE_MS=60000
# Dashboard cache TTL (ms). Default: 300000 (5 min). No auto-poll — use Refresh.
# VITE_ATFX_DASHBOARD_STALE_MS=300000