# =============================================================================
# at_dashboard — copy to .env and fill in values (never commit .env)
# =============================================================================

# --- Clerk (required — app won't start without this) ---
# https://dashboard.clerk.com → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=

# --- ATFX Salesforce REST API (required for live dashboard data) ---
# Same host and token as the SalesforceATFX_mcp server (MCP_ACCESS_TOKEN).
# Auth: Authorization: Bearer <token> on https://<host>/api/*
VITE_ATFX_API_URL=https://atfxmcp.westus2.cloudapp.azure.com
VITE_ATFX_API_TOKEN=

# --- ATFX client tuning (optional) ---
# TanStack Query staleTime for semantic endpoints (ms). Default: 60000
# VITE_ATFX_QUERY_STALE_MS=60000
# Dashboard refetch interval (ms). Default: 30000
# VITE_ATFX_DASHBOARD_POLL_MS=30000